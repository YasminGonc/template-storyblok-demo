{
  "$schema": "https://schema.croct.com/json/v1/template.json",
  "title": "My template",
  "description": "My template description",
  "actions": [
    {
      "name": "create-resource",
      "resources": {
        "audiences": {
          "sportswear-campaign": {
            "name": "Sportswear campaign",
            "criteria": "campaign's name is \"sports\""
          },
          "returning-users": {
            "name": "Returning users",
            "criteria": "user is returning"
          },
          "new-users": {
            "name": "New users",
            "criteria": "user is not returning"
          },
          "couponers": {
            "name": "Couponers",
            "criteria": "user has completed goal \"coupon-redemption\""
          },
          "subscriber": {
            "name": "Subscribers",
            "criteria": "user has completed goal \"newsletter-signup\""
          },
          "buyers": {
            "name": "Buyers",
            "criteria": "user has placed order"
          },
          "location-south-america": {
            "name": "Visitors from South America",
            "criteria": "location's continent's name is \"South America\""
          },
          "location-north-america": {
            "name": "Visitors from North America",
            "criteria": "location's continent's name is \"North America\""
          },
          "location-europe": {
            "name": "Visitors from Europe",
            "criteria": "location's continent's name is \"Europe\""
          },
          "interested-in-sportswear": {
            "name": "Interested in Sportswear",
            "criteria": "user has viewed product with category \"Sportswear\" in the last 5 minutes"
          },
          "interest-elegant-clothing": {
            "name": "Interested in Elegant Clothing",
            "criteria": "user has viewed product with category \"Elegant\" in the last 5 minutes"
          },
          "all-users": {
            "name": "All Users",
            "criteria": "true"
          }
        },
        "components": {
          "note": {
            "name": "Note",
            "schema": {
              "type": "structure",
              "attributes": {
                "content": {
                  "type": {
                    "type": "text",
                    "format": "multiline"
                  },
                  "label": "content",
                  "optional": false,
                  "position": 0
                }
              }
            }
          },
          "checkout-callout": {
            "name": "Checkout callout",
            "schema": {
              "type": "structure",
              "attributes": {
                "icon": {
                  "type": {
                    "id": "@croct/file",
                    "type": "reference",
                    "properties": {
                      "allowedTypes": [
                        "image/png",
                        "image/jpeg",
                        "image/jp2",
                        "image/webp",
                        "image/gif",
                        "image/svg+xml",
                        "image/avif"
                      ]
                    }
                  },
                  "label": "icon",
                  "optional": false,
                  "position": 0
                },
                "text": {
                  "type": {
                    "type": "text"
                  },
                  "label": "text",
                  "optional": false,
                  "position": 2
                },
                "title": {
                  "type": {
                    "type": "text"
                  },
                  "label": "title",
                  "optional": false,
                  "position": 1
                }
              }
            }
          },
          "cta": {
            "name": "CTA",
            "schema": {
              "type": "structure",
              "attributes": {
                "link": {
                  "type": {
                    "type": "text"
                  },
                  "label": "link",
                  "optional": false,
                  "position": 1
                },
                "label": {
                  "type": {
                    "type": "text"
                  },
                  "label": "label",
                  "optional": false,
                  "position": 0
                }
              }
            }
          },
          "announcement-bar": {
            "name": "Announcement bar",
            "schema": {
              "type": "structure",
              "attributes": {
                "cta": {
                  "type": {
                    "type": "list",
                    "items": {
                      "id": "cta",
                      "type": "reference"
                    },
                    "maximumLength": 1,
                    "minimumLength": 1
                  },
                  "label": "cta",
                  "optional": true,
                  "position": 1
                },
                "text": {
                  "type": {
                    "type": "text"
                  },
                  "label": "text",
                  "optional": false,
                  "position": 0
                }
              }
            }
          },
          "hero-section": {
            "name": "Hero section",
            "schema": {
              "type": "structure",
              "attributes": {
                "cta": {
                  "type": {
                    "type": "list",
                    "items": {
                      "id": "cta",
                      "type": "reference"
                    },
                    "maximumLength": 1,
                    "minimumLength": 1
                  },
                  "label": "cta",
                  "optional": false,
                  "position": 2
                },
                "image": {
                  "type": {
                    "id": "@croct/file",
                    "type": "reference",
                    "properties": {
                      "allowedTypes": [
                        "image/png",
                        "image/jpeg",
                        "image/jp2",
                        "image/webp",
                        "image/gif",
                        "image/svg+xml",
                        "image/avif"
                      ]
                    }
                  },
                  "label": "image",
                  "optional": false,
                  "position": 3
                },
                "tagline": {
                  "type": {
                    "type": "text"
                  },
                  "label": "tagline",
                  "optional": true,
                  "position": 1
                },
                "headline": {
                  "type": {
                    "type": "text"
                  },
                  "label": "headline",
                  "optional": false,
                  "position": 0
                }
              }
            }
          },
          "coupon-list": {
            "name": "Coupon list",
            "description": "A list of coupons.",
            "schema": {
              "type": "structure",
              "title": "Coupon list",
              "attributes": {
                "coupons": {
                  "type": {
                    "type": "list",
                    "items": {
                      "type": "structure",
                      "attributes": {
                        "code": {
                          "type": {
                            "type": "text",
                            "pattern": "[a-z0-9-]+",
                            "maximumLength": 30,
                            "minimumLength": 3
                          },
                          "label": "Code",
                          "private": false,
                          "optional": false,
                          "position": 0,
                          "description": "The coupon code."
                        },
                        "rule": {
                          "type": {
                            "type": "text",
                            "minimumLength": 1
                          },
                          "label": "Rule",
                          "private": false,
                          "optional": false,
                          "position": 2,
                          "description": "The eligibility condition for the coupon."
                        },
                        "title": {
                          "type": {
                            "type": "text",
                            "minimumLength": 1
                          },
                          "label": "Title",
                          "private": false,
                          "optional": false,
                          "position": 1,
                          "description": "Display name shown after the coupon is applied."
                        },
                        "discount": {
                          "type": {
                            "type": "number",
                            "integer": true,
                            "maximum": 100,
                            "minimum": 0
                          },
                          "label": "Discount",
                          "private": false,
                          "optional": true,
                          "position": 3,
                          "description": "Percentage discount from 0% to 100%."
                        },
                        "eligible": {
                          "type": {
                            "type": "boolean",
                            "label": {
                              "true": "Yes",
                              "false": "No"
                            },
                            "default": false
                          },
                          "label": "Eligible",
                          "private": false,
                          "optional": false,
                          "position": 6,
                          "description": "Whether the current user is eligible for this coupon."
                        },
                        "maxDiscount": {
                          "type": {
                            "type": "number",
                            "minimum": 0
                          },
                          "label": "Max discount",
                          "private": false,
                          "optional": true,
                          "position": 4,
                          "description": "Maximum discount as an absolute monetary value. Omit for no cap"
                        },
                        "freeShipping": {
                          "type": {
                            "type": "boolean",
                            "label": {
                              "true": "Yes",
                              "false": "No"
                            },
                            "default": false
                          },
                          "label": "Free shipping",
                          "private": false,
                          "optional": false,
                          "position": 5,
                          "description": "Whether the coupon waives the shipping fee."
                        }
                      }
                    },
                    "itemLabel": "Coupon"
                  },
                  "label": "Coupons",
                  "private": false,
                  "optional": false,
                  "position": 0
                }
              },
              "description": "A list of coupons."
            }
          }
        },
        "slots": {
          "checkout-callout": {
            "name": "Checkout callout",
            "component": "checkout-callout",
            "content": {
              "en-us": {
                "type": "structure",
                "attributes": {
                  "icon": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "https://a.storyblok.com/f/289964601464397/150x150/bcac64f80b/gift-icon-blue.svg"
                    }
                  },
                  "text": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "Add a personal touch to your order."
                    }
                  },
                  "title": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "Free gift wrapping on orders over €100"
                    }
                  }
                }
              }
            }
          },
          "site-wide-top-bar": {
            "name": "Site-wide top bar",
            "component": "announcement-bar",
            "content": {
              "en-us": {
                "type": "structure",
                "attributes": {
                  "cta": {
                    "type": "list",
                    "items": [
                      {
                        "type": "structure",
                        "attributes": {
                          "link": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "catalog/"
                            }
                          },
                          "label": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "Shop now"
                            }
                          }
                        }
                      }
                    ]
                  },
                  "text": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "Free shipping for your location."
                    }
                  }
                }
              }
            }
          },
          "home-hero": {
            "name": "Home hero",
            "component": "hero-section",
            "content": {
              "en-us": {
                "type": "structure",
                "attributes": {
                  "cta": {
                    "type": "list",
                    "items": [
                      {
                        "type": "structure",
                        "attributes": {
                          "link": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "catalog/"
                            }
                          },
                          "label": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "Shop now"
                            }
                          }
                        }
                      }
                    ]
                  },
                  "image": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "https://a.storyblok.com/f/289964601464397/4240x2827/788dbcaf4d/fallback.png"
                    }
                  },
                  "tagline": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "Sporty or elegant, we got you covered."
                    }
                  },
                  "headline": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "Effortless style for everyday moments"
                    }
                  }
                }
              }
            }
          },
          "coupons": {
            "name": "Coupons",
            "component": "coupon-list",
            "content": {
              "en-us": {
                "type": "structure",
                "attributes": {
                  "coupons": {
                    "type": "list",
                    "items": [
                      {
                        "type": "structure",
                        "label": "First purchase",
                        "attributes": {
                          "code": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "welcome"
                            }
                          },
                          "rule": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "Discount available in your first visit only."
                            }
                          },
                          "title": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "10% OFF on your first purchase."
                            }
                          },
                          "discount": {
                            "type": "number",
                            "value": {
                              "type": "static",
                              "value": 10
                            }
                          },
                          "eligible": {
                            "type": "boolean",
                            "value": {
                              "type": "dynamic",
                              "default": true,
                              "nullable": false,
                              "expression": "user's stats' order is 0"
                            }
                          },
                          "maxDiscount": {
                            "type": "number",
                            "value": {
                              "type": "static",
                              "value": 100
                            }
                          },
                          "freeShipping": {
                            "type": "boolean",
                            "value": {
                              "type": "static",
                              "value": false
                            }
                          }
                        }
                      },
                      {
                        "type": "structure",
                        "attributes": {
                          "code": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "MP10"
                            }
                          },
                          "rule": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "Cupom do MP"
                            }
                          },
                          "title": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "Cupom do MP"
                            }
                          },
                          "discount": {
                            "type": "number",
                            "value": {
                              "type": "static",
                              "value": 10
                            }
                          },
                          "eligible": {
                            "type": "boolean",
                            "value": {
                              "type": "static",
                              "value": true
                            }
                          },
                          "maxDiscount": {
                            "type": "number",
                            "value": {
                              "type": "static",
                              "value": 50
                            }
                          },
                          "freeShipping": {
                            "type": "boolean",
                            "value": {
                              "type": "static",
                              "value": false
                            }
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        },
