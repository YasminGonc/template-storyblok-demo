          },
          {
            "name": "Simple AB test",
            "draft": false,
            "audiences": [
              "all-users"
            ],
            "slots": [
              "home-hero"
            ],
            "content": {
              "default": {},
              "segmented": []
            },
            "experiment": {
              "name": "Home hero image",
              "goalId": "hero-cta-click",
              "crossDevice": false,
              "traffic": 1,
              "variants": [
                {
                  "name": "Variant A",
                  "content": {
                    "default": {
                      "home-hero": {
                        "en-us": {
                          "type": "structure",
