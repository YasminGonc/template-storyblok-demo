{
  "$schema": "https://schema.croct.com/json/v1/template.json",
  "title": "My template",
  "description": "My template description",
  "actions": [
    {
      "name": "create-resource",
      "resources": {
        "audiences": {
          "location-south-america": {
            "name": "Visitors from South America",
            "criteria": "location's continent's name is \"South America\""
          },
          "location-north-america": {
            "name": "Visitors from North America",
            "criteria": "location's continent's name is \"North America\""
          },
          "location-europe": {
            "name": "Visitors from Europe",
            "criteria": "location's continent's name is \"Europe\""
          }
        },
        "components": {
          "checkout-callout": {
            "name": "Checkout callout",
            "schema": {
              "type": "structure",
              "attributes": {
                "icon": {
                  "type": {
                    "id": "@croct/file",
                    "type": "reference",
                    "properties": {
                      "allowedTypes": [
                        "image/png",
                        "image/jpeg",
                        "image/jp2",
                        "image/webp",
                        "image/gif",
                        "image/svg+xml",
                        "image/avif"
                      ]
                    }
                  },
                  "label": "icon",
                  "optional": false,
                  "position": 0
                },
                "text": {
                  "type": {
                    "type": "text"
                  },
                  "label": "text",
                  "optional": false,
                  "position": 2
                },
                "title": {
                  "type": {
                    "type": "text"
                  },
                  "label": "title",
                  "optional": false,
                  "position": 1
                }
              }
            }
          },
          "cta": {
            "name": "CTA",
            "schema": {
              "type": "structure",
              "attributes": {
                "link": {
                  "type": {
                    "type": "text"
                  },
                  "label": "link",
                  "optional": false,
                  "position": 1
                },
                "label": {
                  "type": {
                    "type": "text"
                  },
                  "label": "label",
                  "optional": false,
                  "position": 0
                }
              }
            }
          },
          "announcement-bar": {
            "name": "Announcement bar",
            "schema": {
              "type": "structure",
              "attributes": {
                "cta": {
                  "type": {
                    "type": "list",
                    "items": {
                      "id": "cta",
                      "type": "reference"
                    },
                    "maximumLength": 1,
                    "minimumLength": 1
                  },
                  "label": "cta",
                  "optional": true,
                  "position": 1
                },
                "text": {
                  "type": {
                    "type": "text"
                  },
                  "label": "text",
                  "optional": false,
                  "position": 0
                }
              }
            }
          }
        },
        "slots": {
          "checkout-callout": {
            "name": "Checkout callout",
            "component": "checkout-callout",
            "content": {
              "en-us": {
                "type": "structure",
                "attributes": {
                  "icon": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "https://a.storyblok.com/f/289964601464397/150x150/bcac64f80b/gift-icon-blue.svg"
                    }
                  },
                  "text": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "Add a personal touch to your order."
                    }
                  },
                  "title": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "Free gift wrapping on orders over €100"
                    }
                  }
                }
              }
            }
          },
          "site-wide-top-bar": {
            "name": "Site-wide top bar",
            "component": "announcement-bar",
            "content": {
              "en-us": {
                "type": "structure",
                "attributes": {
                  "cta": {
                    "type": "list",
                    "items": [
                      {
                        "type": "structure",
                        "attributes": {
                          "link": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "catalog/"
                            }
                          },
                          "label": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "Shop now"
                            }
                          }
                        }
                      }
                    ]
                  },
                  "text": {
                    "type": "text",
                    "value": {
                      "type": "static",
                      "value": "Free shipping for your location."
                    }
                  }
                }
              }
            }
          }
        },
        "experiences": [
          {
            "name": "Free shipping",
            "draft": false,
            "audiences": [
              "location-europe",
              "location-north-america",
              "location-south-america"
            ],
            "slots": [
              "checkout-callout",
              "site-wide-top-bar"
            ],
            "content": {
              "default": {},
              "segmented": [
                {
                  "audiences": [
                    "location-europe"
                  ],
                  "content": {
                    "checkout-callout": {
                      "en-us": {
                        "type": "structure",
                        "attributes": {
                          "icon": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "https://a.storyblok.com/f/289964601464397/150x150/64398618fd/package-icon.svg"
                            }
                          },
                          "text": {
                            "type": "text",
                            "value": {
                              "type": "dynamic",
                              "default": "Please add more items to your cart.",
                              "nullable": false,
                              "expression": "\"Your order will be delivered for free.\"\nif cart's total is greater than 300\nelse \"Please add more items to your cart.\""
                            }
                          },
                          "title": {
                            "type": "text",
                            "value": {
                              "type": "dynamic",
                              "default": "Free shipping for orders over €300",
                              "nullable": false,
                              "expression": "\"Free shipping to \" & (location's country's name or else \"Europe\")\nif cart's total is greater than 300\nelse \"Free shipping to \" & (location's country's name or else \"Europe\") & \" for orders over €300\""
                            }
                          }
                        }
                      }
                    },
                    "site-wide-top-bar": {
                      "en-us": {
                        "type": "structure",
                        "attributes": {
                          "cta": {
                            "type": "list",
                            "items": [
                              {
                                "type": "structure",
                                "label": "Item",
                                "attributes": {
                                  "link": {
                                    "type": "text",
                                    "value": {
                                      "type": "static",
                                      "value": "https://storyblok-next-personalization.vercel.app/catalog"
                                    }
                                  },
                                  "label": {
                                    "type": "text",
                                    "value": {
                                      "type": "static",
                                      "value": "Shop now"
                                    }
                                  }
                                }
                              }
                            ]
                          },
                          "text": {
                            "type": "text",
                            "value": {
                              "type": "dynamic",
                              "default": "Free shipping to Europe for orders over €300.",
                              "nullable": false,
                              "expression": "\"Free shipping to \"\n& (location's country's name or else \"Europe\")\n& \" for orders over €300.\""
                            }
                          }
                        }
                      }
                    }
                  }
                },
                {
                  "audiences": [
                    "location-north-america"
                  ],
                  "content": {
                    "checkout-callout": {
                      "en-us": {
                        "type": "structure",
                        "attributes": {
                          "icon": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "https://a.storyblok.com/f/289964601464397/150x150/64398618fd/package-icon.svg"
                            }
                          },
                          "text": {
                            "type": "text",
                            "value": {
                              "type": "dynamic",
                              "default": "Please add more items to your cart.",
                              "nullable": false,
                              "expression": "\"Your order will be delivered for free.\"\nif cart's total is greater than 200\nelse \"Please add more items to your cart.\""
                            }
                          },
                          "title": {
                            "type": "text",
                            "value": {
                              "type": "dynamic",
                              "default": "Free shipping for orders over €200",
                              "nullable": false,
                              "expression": "\"Free shipping to \" & (location's country's name or else \"North America\")\nif cart's total is greater than 200\nelse \"Free shipping to \" & (location's country's name or else \"North America\") & \" for orders over €200\""
                            }
                          }
                        }
                      }
                    },
                    "site-wide-top-bar": {
                      "en-us": {
                        "type": "structure",
                        "attributes": {
                          "cta": {
                            "type": "list",
                            "items": [
                              {
                                "type": "structure",
                                "label": "Item",
                                "attributes": {
                                  "link": {
                                    "type": "text",
                                    "value": {
                                      "type": "static",
                                      "value": "https://storyblok-next-personalization.vercel.app/catalog"
                                    }
                                  },
                                  "label": {
                                    "type": "text",
                                    "value": {
                                      "type": "static",
                                      "value": "Shop now"
                                    }
                                  }
                                }
                              }
                            ]
                          },
                          "text": {
                            "type": "text",
                            "value": {
                              "type": "dynamic",
                              "default": "Free shipping to North America for orders over €200.",
                              "nullable": false,
                              "expression": "\"Free shipping to \"\n& (location's country's name or else \"North America\")\n& \" for orders over €200.\""
                            }
                          }
                        }
                      }
                    }
                  }
                },
                {
                  "audiences": [
                    "location-south-america"
                  ],
                  "content": {
                    "checkout-callout": {
                      "en-us": {
                        "type": "structure",
                        "attributes": {
                          "icon": {
                            "type": "text",
                            "value": {
                              "type": "static",
                              "value": "https://a.storyblok.com/f/289964601464397/150x150/64398618fd/package-icon.svg"
                            }
                          },
                          "text": {
                            "type": "text",
                            "value": {
                              "type": "dynamic",
                              "default": "Please add more items to your cart.",
                              "nullable": false,
                              "expression": "\"Your order will be delivered for free.\"\nif cart's total is greater than 400\nelse \"Please add more items to your cart.\""
                            }
                          },
                          "title": {
                            "type": "text",
                            "value": {
                              "type": "dynamic",
                              "default": "Free shipping for orders over €400",
                              "nullable": false,
                              "expression": "\"Free shipping to \" & (location's country's name or else \"South America\")\nif cart's total is greater than 400\nelse \"Free shipping to \" & (location's country's name or else \"South America\") & \" for orders over €400\""
                            }
                          }
                        }
                      }
                    },
                    "site-wide-top-bar": {
                      "en-us": {
                        "type": "structure",
                        "attributes": {
                          "cta": {
                            "type": "list",
                            "items": [
                              {
                                "type": "structure",
                                "label": "Item",
                                "attributes": {
                                  "link": {
                                    "type": "text",
                                    "value": {
                                      "type": "static",
                                      "value": "https://storyblok-next-personalization.vercel.app/catalog"
                                    }
                                  },
                                  "label": {
                                    "type": "text",
                                    "value": {
                                      "type": "static",
                                      "value": "Shop now"
                                    }
                                  }
                                }
                              }
                            ]
                          },
                          "text": {
                            "type": "text",
                            "value": {
                              "type": "dynamic",
                              "default": "Free shipping to South America for orders over €400.",
                              "nullable": false,
                              "expression": "\"Free shipping to \"\n& (location's country's name or else \"South America\")\n& \" for orders over €400.\""
                            }
                          }
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}